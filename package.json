{
  "name": "layout-v2",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Independent React layout engine extracted from ofive.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4175 --strictPort",
    "build": "tsc -p tsconfig.build.json && vite build",
    "prepare": "npm run build",
    "test": "bun test",
    "test:e2e": "bunx playwright test --config playwright.config.ts --reporter=line"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}